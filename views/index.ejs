<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Post CR</title>
</head>
<body>
    <div class="main-container bg-gray-900 min-w-screen min-h-screen text-white">
        <div class="form-main-container h-screen flex justify-center items-center">
        <div class="login-form-container border-gray-500 bg-gray-700 border rounded-lg flex flex-col items-center p-10">
            <h3 class="text-3xl tracking-tight mb-4">Login</h3>
            <form action="/login" method="post" class="flex flex-col gap-4">
                <input type="text" placeholder="Username or email" class="p-2 outline-none border rounded border-gray-400">
                <input type="password" placeholder="Password" class="p-2 outline-none border rounded border-gray-400">
                <input type="button" value="Login" class="border border-gray-400 rounded bg-orange-400 p-2">
                <input type="button" value="Sign Up" class="border border-gray-400 rounded bg-zinc-400 p-2">
            </form>
        </div>
        </div>
    </div>
</body>
</html>